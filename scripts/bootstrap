#!/bin/sh
#|
exec ros -Q -- $0 "$@"
|#
;; scripts/bootstrap — Session state summary for the Product Builder agent
;;
;; Purpose: Produce a compact briefing so the agent can reconstruct project
;; context at session start without reading every artifact individually.
;; Satisfies: @req-3

(ql:quickload :cl-ppcre :silent t)

(defun run-command (cmd)
  ;; Run a shell command and return trimmed stdout, or empty string on failure.
  (handler-case
    (string-trim '(#\Space #\Newline #\Return)
      (uiop:run-program (list "sh" "-c" cmd)
                        :output :string :ignore-error-status t))
    (error () "")))

(defun extract-mission (lines)
  ;; Extract the mission paragraph from a list of VISION.md lines.
  (let ((in-mission nil) (mission-lines '()))
    (dolist (line lines)
      (cond
        ((and (not in-mission) (uiop:string-prefix-p "## Mission" line))
         (setf in-mission t))
        ((and in-mission (uiop:string-prefix-p "## " line))
         (return))
        ((and in-mission (plusp (length (string-trim '(#\Space) line))))
         (push (string-trim '(#\Space) line) mission-lines))))
    (format nil "~{~a~^ ~}" (nreverse mission-lines))))

(defun find-proposal-adrs (adr-dir)
  ;; Return list of (path title blocked-task) for all Proposed ADRs.
  (when (uiop:directory-exists-p adr-dir)
    (loop for f in (sort (uiop:directory-files adr-dir "ADR-*.md")
                         #'string< :key #'namestring)
          for text = (uiop:read-file-string f)
          when (search "**Status:** Proposed" text)
          collect (let* ((title-match (nth-value 1 (cl-ppcre:scan-to-strings "^# (.+)" text)))
                         (title (if title-match (aref title-match 0) (file-namestring f)))
                         (blocked-match (nth-value 1 (cl-ppcre:scan-to-strings
                                                       "\\*\\*Blocked task:\\*\\*\\s*(\\S+)" text)))
                         (blocked (when blocked-match (aref blocked-match 0))))
                    (list f title blocked)))))

(defun main (&rest argv)
  (declare (ignore argv))
  (let ((vision-path (merge-pathnames "VISION.md" (uiop:getcwd))))
    (format t "=== Product Builder — Session Bootstrap ===~%~%")
    (unless (probe-file vision-path)
      (format t "No VISION.md found - requirements elicitation required.~%")
      (uiop:quit 0))
    (let* ((lines (uiop:read-file-lines vision-path))
           (project-name (string-trim '(#\Space #\#) (first lines)))
           (mission (extract-mission lines)))
      (format t "Project : ~a~%Mission : ~a~%~%" project-name mission))
    (format t "--- Backlog ---~%")
    (let ((ready (run-command "bd ready 2>/dev/null")))
      (format t "~a~%~%" (if (plusp (length ready)) ready "(no unblocked tasks)")))
    (format t "--- Open ADRs awaiting decision ---~%")
    (let ((proposals (find-proposal-adrs (merge-pathnames "adrs/" (uiop:getcwd)))))
      (if proposals
          (dolist (entry proposals)
            (destructuring-bind (path title blocked) entry
              (format t "  [proposed] ~a - ~a~@[ [blocks: ~a]~]~%"
                      (uiop:native-namestring path) title blocked)))
          (format t "  (none)~%")))
    (terpri)
    (format t "--- Recent commits ---~%")
    (let ((log (run-command "git log --oneline -5 2>/dev/null")))
      (format t "~a~%~%" (if (plusp (length log)) log "  (no git history)")))
    (format t "=== Run `bd ready` for full unblocked task list ===~%")))
