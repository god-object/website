#!/bin/sh
#|
exec ros -Q -- $0 "$@"
|#
;; scripts/epic-summary — Epic Summary skeleton generator
;;
;; Purpose: Query Beads for closed tasks under an epic, cross-reference their
;; BDD scenario tags, and output a structured Epic Summary skeleton.
;; Deterministic sections (scenarios, tasks, ADR statuses) are extracted
;; mechanically; the agent fills in prose on top.
;; Satisfies: @demo-1
;;
;; Usage: scripts/epic-summary <epic-id>

(ql:quickload '(:cl-ppcre :yason) :silent t)

(defun run-json (cmd-list)
  ;; Run a command and parse its JSON output. Returns #() on failure.
  (handler-case
    (yason:parse (uiop:run-program cmd-list :output :string :ignore-error-status t))
    (error () #())))

(defun get-scenario-name (tag specs-dir)
  ;; Look up the scenario name for a given @tag across all .feature files.
  ;; Satisfies: ADR-004 — tags are file-scoped and unique within the project.
  (dolist (f (sort (uiop:directory-files specs-dir "*.feature") #'string< :key #'namestring))
    (loop for (line next-line) on (uiop:read-file-lines f)
          when (string= (string-trim '(#\Space #\Tab) line) tag)
          do (let ((m (nth-value 1 (cl-ppcre:scan-to-strings
                                     "^Scenario(?:\\s+Outline)?:\\s+(.+)"
                                     (string-trim '(#\Space #\Tab) (or next-line ""))))))
               (when m (return-from get-scenario-name
                         (string-trim '(#\Space) (aref m 0)))))))
  nil)

(defun find-adrs-with-status (adr-dir status)
  ;; Return list of (path . title) for ADRs matching the given status.
  (when (uiop:directory-exists-p adr-dir)
    (loop for f in (sort (uiop:directory-files adr-dir "ADR-*.md") #'string< :key #'namestring)
          for text = (uiop:read-file-string f)
          when (search (format nil "**Status:** ~a" status) text)
          collect (let* ((m (nth-value 1 (cl-ppcre:scan-to-strings "^# (.+)" text))))
                    (cons (uiop:native-namestring f)
                          (if m (aref m 0) (file-namestring f)))))))

(defun main (&rest argv)
  (let ((args argv))
    (when (null args)
      (format *error-output* "Usage: scripts/epic-summary <epic-id>~%")
      (uiop:quit 1))
    (let* ((epic-id (first args))
           (epic-data (run-json (list "bd" "show" epic-id "--json")))
           (epic-title (if (and (vectorp epic-data) (plusp (length epic-data)))
                           (gethash "title" (aref epic-data 0) "Unknown epic")
                           "Unknown epic"))
           (all-issues (run-json '("bd" "list" "--all" "--json")))
           (children (loop for i across all-issues
                           when (string= (gethash "parent" i "") epic-id) collect i))
           (closed (remove-if-not (lambda (i) (string= (gethash "status" i "") "closed")) children))
           (open   (remove-if     (lambda (i) (string= (gethash "status" i "") "closed")) children))
           (seen-tags (make-hash-table :test #'equal))
           (tag-details '())
           (specs-dir (merge-pathnames "specs/bdd/" (uiop:getcwd)))
           (proposed-adrs (find-adrs-with-status (merge-pathnames "adrs/" (uiop:getcwd)) "Proposed"))
           (deferred-adrs (find-adrs-with-status (merge-pathnames "adrs/" (uiop:getcwd)) "Deferred")))
      (dolist (task closed)
        (cl-ppcre:do-matches-as-strings (tag "@[a-z][a-z0-9_-]*-\\d+" (or (gethash "description" task) ""))
          (unless (gethash tag seen-tags)
            (setf (gethash tag seen-tags) t)
            (push (cons tag (get-scenario-name tag specs-dir)) tag-details))))
      (setf tag-details (sort (nreverse tag-details) #'string< :key #'car))
      (format t "# Epic Summary: ~a (~a)~%~%" epic-title epic-id)
      (format t "## What was built~%<!-- Describe what this epic delivered in 2-4 sentences. -->~%~%")
      (format t "## BDD scenarios satisfied~%")
      (if tag-details
          (dolist (p tag-details) (format t "- ~a~@[: ~a~]~%" (car p) (cdr p)))
          (format t "- (no scenario tags found in closed task descriptions)~%"))
      (terpri)
      (format t "## Beads tasks closed~%")
      (if closed
          (dolist (t closed) (format t "- ~a: ~a~%" (gethash "id" t "") (gethash "title" t "")))
          (format t "- (no closed tasks found under this epic)~%"))
      (terpri)
      (when open
        (format t "## Tasks not yet closed [WARNING: epic incomplete]~%")
        (dolist (t open)
          (format t "- ~a: ~a (~a)~%"
                  (gethash "id" t "") (gethash "title" t "") (gethash "status" t "?")))
        (terpri))
      (format t "## Open proposal ADRs~%")
      (if proposed-adrs
          (dolist (p proposed-adrs) (format t "- [proposed] ~a - ~a~%" (car p) (cdr p)))
          (format t "- (none)~%"))
      (terpri)
      (format t "## Deferred decisions~%")
      (if deferred-adrs
          (dolist (p deferred-adrs) (format t "- [deferred] ~a - ~a~%" (car p) (cdr p)))
          (format t "- (none)~%"))
      (terpri)
      (format t "## Known gaps~%")
      (format t "<!-- List anything descoped, partially implemented, or that needs~%")
      (format t "     revisiting. Gaps caught now are cheaper than gaps in production. -->~%"))))
