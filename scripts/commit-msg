#!/bin/sh
#|
exec ros -Q -- $0 "$@"
|#
;; scripts/commit-msg — Conventional commit message generator
;;
;; Purpose: Generate a Conventional Commits message from the staged diff and
;; a Beads task, so the agent produces consistent messages without recalling
;; the format from scratch. The agent reviews and adjusts the description line.
;; Satisfies: @dev-4
;;
;; Usage: scripts/commit-msg <task-id>

(ql:quickload '(:cl-ppcre :yason) :silent t)

;; Map Beads issue types to Conventional Commits types.
;; Satisfies: @dev-4 — commit message follows the CC specification.
(defparameter *cc-type-map*
  '(("feature" . "feat")
    ("bug"     . "fix")
    ("docs"    . "docs")
    ("test"    . "test")
    ("chore"   . "chore")
    ("epic"    . "feat")))

(defun run-command (cmd)
  (handler-case
    (string-trim '(#\Space #\Newline #\Return)
      (uiop:run-program (list "sh" "-c" cmd) :output :string :ignore-error-status t))
    (error () "")))

(defun get-task (task-id)
  ;; Fetch task metadata from Beads. Returns (values title issue-type).
  (handler-case
    (let* ((output (uiop:run-program (list "bd" "show" task-id "--json")
                                     :output :string :ignore-error-status t))
           (data (yason:parse output))
           (item (if (vectorp data) (aref data 0) data)))
      (values (gethash "title" item task-id)
              (or (gethash "issue_type" item) (gethash "type" item) "task")))
    (error () (values task-id "task"))))

(defun derive-scope (staged-files)
  ;; Derive a CC scope from staged files.
  ;; Uses the most common top-level directory; falls back to empty string.
  (let ((dir-counts (make-hash-table :test #'equal)))
    (dolist (f staged-files)
      (let ((slash-pos (position #\/ f)))
        (when slash-pos
          (incf (gethash (subseq f 0 slash-pos) dir-counts 0)))))
    (let ((best nil) (best-count 0))
      (maphash (lambda (dir count)
                 (when (> count best-count)
                   (setf best dir best-count count)))
               dir-counts)
      (or best ""))))

(defun lowercase-first (s)
  ;; Lowercase the first character of a string.
  (if (zerop (length s)) s
      (concatenate 'string (string (char-downcase (char s 0))) (subseq s 1))))

(defun strip-trailing-punct (s)
  ;; Remove trailing punctuation (. ! ?) from a string.
  (cl-ppcre:regex-replace "[.!?]+$" s ""))

(defun main (&rest argv)
  (let ((args argv))
    (when (null args)
      (format *error-output* "Usage: scripts/commit-msg <task-id>~%")
      (uiop:quit 1))
    (let* ((task-id (first args)))
      (multiple-value-bind (title issue-type) (get-task task-id)
        (let* ((cc-type (or (cdr (assoc issue-type *cc-type-map* :test #'string=)) "chore"))
               (staged-files (remove "" (uiop:split-string
                                          (run-command "git diff --staged --name-only")
                                          :separator '(#\Newline))
                                     :test #'string=))
               (scope (derive-scope staged-files))
               (scope-str (if (plusp (length scope)) (format nil "(~a)" scope) ""))
               (diff-stat-lines (remove "" (uiop:split-string
                                             (run-command "git diff --staged --stat")
                                             :separator '(#\Newline))
                                        :test #'string=))
               (stat-line (string-trim '(#\Space) (or (first (last diff-stat-lines)) "")))
               (description (strip-trailing-punct (lowercase-first title))))
          (format t "~a~a: ~a~%~%" cc-type scope-str description)
          (when (plusp (length stat-line))
            (format t "~a~%~%" stat-line))
          (format t "Task: ~a~%" task-id))))))
