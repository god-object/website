#!/usr/bin/env python3
# scripts/commit-msg — Conventional commit message generator
#
# Purpose: Generate a Conventional Commits message from the staged diff and
# a Beads task, so the agent produces consistent messages without recalling
# the format from scratch. The agent reviews and adjusts the description line.
# Satisfies: @dev-4
#
# Usage: scripts/commit-msg <task-id>

import json
import re
import subprocess
import sys
from collections import Counter


def run(cmd):
    """Run a shell command and return stdout, empty string on failure."""
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        return r.stdout.strip()
    except Exception:
        return ""


# Map Beads issue types to Conventional Commits types.
# Satisfies: @dev-4 — commit message follows the CC specification.
CC_TYPE_MAP = {
    "feature": "feat",
    "bug": "fix",
    "docs": "docs",
    "test": "test",
    "chore": "chore",
    "epic": "feat",
}


def get_task(task_id):
    """Fetch task metadata from Beads. Returns (title, issue_type)."""
    try:
        result = subprocess.run(
            ["bd", "show", task_id, "--json"],
            capture_output=True, text=True
        )
        data = json.loads(result.stdout)
        item = data[0] if isinstance(data, list) else data
        return item.get("title", task_id), item.get("issue_type") or item.get("type", "task")
    except Exception:
        return task_id, "task"


def derive_scope(staged_files):
    """
    Derive a CC scope from staged files.
    Uses the most common top-level directory; falls back to empty string.
    """
    dirs = [
        parts[0]
        for f in staged_files
        if len(parts := f.split("/")) > 1
    ]
    if not dirs:
        return ""
    most_common, _ = Counter(dirs).most_common(1)[0]
    return most_common


def lowercase_first(s):
    """Lowercase the first character of a string (portable, no sed needed)."""
    return s[0].lower() + s[1:] if s else s


def strip_trailing_punct(s):
    return re.sub(r"[.!?]+$", "", s)


def main():
    if len(sys.argv) < 2:
        print("Usage: scripts/commit-msg <task-id>", file=sys.stderr)
        sys.exit(1)

    task_id = sys.argv[1]
    title, issue_type = get_task(task_id)
    cc_type = CC_TYPE_MAP.get(issue_type, "chore")

    staged_files = run("git diff --staged --name-only").splitlines()
    scope = derive_scope(staged_files)
    scope_str = f"({scope})" if scope else ""

    diff_stat = run("git diff --staged --stat").splitlines()
    stat_line = diff_stat[-1].strip() if diff_stat else ""

    description = strip_trailing_punct(lowercase_first(title))

    body_parts = []
    if stat_line:
        body_parts.append(stat_line)
    body_parts.append(f"Task: {task_id}")

    print(f"{cc_type}{scope_str}: {description}")
    print()
    print("\n\n".join(body_parts))


if __name__ == "__main__":
    main()
