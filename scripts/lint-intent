#!/usr/bin/env python3
# scripts/lint-intent — Chain of intent validator (pre-commit hook)
#
# Purpose: Enforce that the chain of intent stays unbroken at commit time.
# Installed as .git/hooks/pre-commit. Checks:
#   1. Staged source files with significant additions contain at least one
#      comment line — a proxy for intent documentation (ADR-003).
#   2. No staged file introduces a bare TODO without a Beads task reference.
# Satisfies: @dev-3
#
# Install:
#   cp scripts/lint-intent .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or run manually before committing:
#   scripts/lint-intent

import re
import subprocess
import sys
from pathlib import Path

# Files with these extensions are exempt from comment-density checks —
# they are data/config files, not intent-bearing source code.
EXEMPT_EXTENSIONS = {
    ".md", ".json", ".lock", ".sum", ".mod", ".txt",
    ".yaml", ".yml", ".toml", ".env", ".csv", ".xml",
}

# Minimum added lines before we require at least one comment.
COMMENT_THRESHOLD = 10

# Comment markers by file extension. Falls back to checking all markers.
COMMENT_MARKERS = {
    ".py":   ["#"],
    ".js":   ["//", "/*", "*"],
    ".ts":   ["//", "/*", "*"],
    ".go":   ["//", "/*"],
    ".rs":   ["//", "/*"],
    ".java": ["//", "/*", "*"],
    ".rb":   ["#"],
    ".sh":   ["#"],
    ".bash": ["#"],
}
DEFAULT_MARKERS = ["//", "#", "--", "/*", "*", "<!--"]

# Beads task ID pattern — product-builder-abc or any project prefix
TASK_REF_PATTERN = re.compile(r"[a-z][a-z0-9]+-[a-z0-9]+", re.IGNORECASE)


def run(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout


def get_staged_diff(file_path):
    return run(f"git diff --staged -- {file_path}")


def count_added_lines(diff):
    """Count lines added in a diff (lines starting with + but not ++)."""
    return sum(1 for line in diff.splitlines() if line.startswith("+") and not line.startswith("++"))


def has_comment(diff, markers):
    """Return True if the diff contains at least one added comment line."""
    for line in diff.splitlines():
        if not line.startswith("+") or line.startswith("++"):
            continue
        stripped = line[1:].lstrip()
        if any(stripped.startswith(m) for m in markers):
            return True
    return False


def find_bare_todos(diff):
    """
    Return lines with TODOs not followed by a Beads task reference.
    A valid TODO looks like: TODO(product-builder-abc) or TODO: product-builder-abc
    """
    bare = []
    for line in diff.splitlines():
        if not line.startswith("+") or line.startswith("++"):
            continue
        if "TODO" not in line:
            continue
        # Check if a task reference appears on the same line
        after_todo = line[line.index("TODO"):]
        if not TASK_REF_PATTERN.search(after_todo):
            bare.append(line[1:].rstrip())  # strip leading +
    return bare


def main():
    staged_files = run("git diff --staged --name-only").strip().splitlines()
    errors = []

    for file_str in staged_files:
        file_path = Path(file_str)
        if not file_path.exists():
            continue  # deleted file
        if file_path.suffix.lower() in EXEMPT_EXTENSIONS:
            continue

        diff = get_staged_diff(file_str)
        if not diff:
            continue

        added = count_added_lines(diff)
        markers = COMMENT_MARKERS.get(file_path.suffix.lower(), DEFAULT_MARKERS)

        # Check 1: significant additions must include at least one comment
        if added >= COMMENT_THRESHOLD and not has_comment(diff, markers):
            errors.append(
                f"{file_str}: {added} lines added with no comments"
                f" - document intent (see ADR-003)"
            )

        # Check 2: no bare TODOs without task references
        for todo_line in find_bare_todos(diff):
            errors.append(
                f"{file_str}: bare TODO without task reference: {todo_line!r}"
                f" - use TODO(<task-id>) instead"
            )

    if not errors:
        print("✓ lint-intent: chain of intent checks passed.")
        sys.exit(0)
    else:
        print("✗ lint-intent: chain of intent violations:\n")
        for err in errors:
            print(f"  ✗ {err}")
        print("\nFix the above before committing. See ADR-003.")
        sys.exit(1)


if __name__ == "__main__":
    main()
