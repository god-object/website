#!/bin/sh
#|
exec ros -Q -- $0 "$@"
|#
;; scripts/lint-intent — Chain of intent validator (pre-commit hook)
;;
;; Purpose: Enforce that the chain of intent stays unbroken at commit time.
;; Installed as .git/hooks/pre-commit. Checks:
;;   1. Staged source files with significant additions contain at least one
;;      comment line — a proxy for intent documentation.
;;   2. No staged file introduces a bare TODO without a Beads task reference.
;; Satisfies: @dev-3
;;
;; Install:
;;   cp scripts/lint-intent .git/hooks/pre-commit
;;   chmod +x .git/hooks/pre-commit

(ql:quickload :cl-ppcre :silent t)

;; Files with these extensions are exempt from comment-density checks.
(defparameter *exempt-extensions*
  '(".md" ".json" ".lock" ".sum" ".mod" ".txt"
    ".yaml" ".yml" ".toml" ".env" ".csv" ".xml"))

(defparameter *comment-threshold* 10)

(defparameter *comment-markers*
  '((".py"   . ("#"))
    (".js"   . ("//" "/*" "*"))
    (".ts"   . ("//" "/*" "*"))
    (".go"   . ("//" "/*"))
    (".rs"   . ("//" "/*"))
    (".java" . ("//" "/*" "*"))
    (".rb"   . ("#"))
    (".sh"   . ("#"))
    (".bash" . ("#"))
    (".lisp" . (";"))
    (".cl"   . (";"))))

(defparameter *default-markers* '("//" "#" "--" "/*" "*" "<!--" ";"))
(defparameter *task-ref-pattern* "[a-z][a-z0-9]+-[a-z0-9]+")

(defun run-command (cmd)
  (handler-case
    (uiop:run-program (list "sh" "-c" cmd) :output :string :ignore-error-status t)
    (error () "")))

(defun count-added-lines (diff)
  ;; Count lines added in a diff (lines starting with + but not ++).
  (loop for line in (uiop:split-string diff :separator '(#\Newline))
        count (and (plusp (length line))
                   (char= (char line 0) #\+)
                   (not (uiop:string-prefix-p "++" line)))))

(defun has-comment-p (diff markers)
  ;; Return true if the diff contains at least one added comment line.
  (dolist (line (uiop:split-string diff :separator '(#\Newline)))
    (when (and (plusp (length line))
               (char= (char line 0) #\+)
               (not (uiop:string-prefix-p "++" line)))
      (let ((stripped (string-left-trim '(#\Space #\Tab) (subseq line 1))))
        (dolist (marker markers)
          (when (uiop:string-prefix-p marker stripped)
            (return-from has-comment-p t))))))
  nil)

(defun find-bare-todos (diff)
  ;; Return added lines with TODOs not followed by a Beads task reference.
  (loop for line in (uiop:split-string diff :separator '(#\Newline))
        when (and (plusp (length line))
                  (char= (char line 0) #\+)
                  (not (uiop:string-prefix-p "++" line))
                  (search "TODO" line)
                  (not (cl-ppcre:scan *task-ref-pattern*
                                      (subseq line (+ (search "TODO" line) 4)))))
        collect (string-right-trim '(#\Space #\Return) (subseq line 1))))

(defun file-extension (path-string)
  ;; Return the lowercased extension including dot, or empty string.
  (let* ((type (pathname-type (pathname path-string))))
    (if (and type (not (eq type :unspecific)))
        (concatenate 'string "." (string-downcase type))
        "")))

(defun main (&rest argv)
  (declare (ignore argv))
  (let* ((staged-output (run-command "git diff --staged --name-only"))
         (staged-files (remove "" (uiop:split-string staged-output :separator '(#\Newline))
                               :test #'string=))
         (errors '()))
    (dolist (file-str staged-files)
      (let ((ext (file-extension file-str)))
        (when (and (probe-file file-str)
                   (not (member ext *exempt-extensions* :test #'string=)))
          (let* ((diff (run-command (format nil "git diff --staged -- ~a" file-str)))
                 (added (count-added-lines diff))
                 (markers (or (cdr (assoc ext *comment-markers* :test #'string=))
                              *default-markers*)))
            (when (and (>= added *comment-threshold*) (not (has-comment-p diff markers)))
              (push (format nil "~a: ~a lines added with no comments - document intent"
                            file-str added) errors))
            (dolist (todo-line (find-bare-todos diff))
              (push (format nil "~a: bare TODO without task reference: ~s - use TODO(<task-id>) instead"
                            file-str todo-line) errors))))))
    (setf errors (nreverse errors))
    (if (null errors)
        (progn (format t "✓ lint-intent: chain of intent checks passed.~%") (uiop:quit 0))
        (progn
          (format t "✗ lint-intent: chain of intent violations:~%~%")
          (dolist (err errors) (format t "  ✗ ~a~%" err))
          (format t "~%Fix the above before committing.~%")
          (uiop:quit 1)))))
