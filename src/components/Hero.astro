---
// Hero section — full-viewport opening statement.
// Satisfies: @co-1 (logo, name, headline above fold), @cl-4 (CTA to #contact)
import heroSrc from "../assets/hero.png";
---

<!--
  Hero image fills the viewport; text content overlaid on top.
  @co-1 — headline visible above the fold.
-->
<!-- @co-4 — 50svh on mobile keeps the image from dominating small screens -->
<section class="relative min-h-[50svh] sm:min-h-svh flex flex-col items-center justify-center text-center" aria-label="Hero">

  <!--
    Hero image — absolute fill behind all content.
    object-cover ensures it fills without distortion at any viewport size. @co-4
  -->
  <img
    src={heroSrc.src}
    alt="God Object — a towering cube over tiny human figures"
    class="absolute inset-0 w-full h-full object-cover select-none"
    draggable="false"
  />

  <!-- Scrim — improves text legibility over the image. @co-1 -->
  <div class="absolute inset-0 bg-go-black/50"></div>

  <!-- Text content — sits above image and scrim via z-10 -->
  <div class="relative z-10 flex flex-col items-center px-6 py-24">

  <!--
    Headline — "Omniscient by design."
    Reclaims the God Object anti-pattern as a virtue: the class that knows
    everything, the company that owns the whole problem.
    @co-1, @co-2
  -->
  <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight leading-tight mb-6 max-w-2xl">
    Omniscient by design.
  </h1>

  <!--
    Subheading — makes the irony land without explaining the joke.
    Describes God Object behaviour (does everything, delegates nothing)
    as a client promise.
    @co-1, @co-2
  -->
  <p class="text-base sm:text-lg text-go-accent/80 max-w-xl leading-relaxed mb-12">
    We take the whole problem. Architecture, implementation,
    deployment&nbsp;— nothing delegated, nothing abstracted away.
  </p>

  <!--
    Primary CTA — smooth scrolls to the contact section.
    Outlined style: technical restraint over conventional filled button.
    @cl-4 — CTA reachable from hero
  -->
  <a
    href="#contact"
    class="inline-block border border-go-white/40 hover:border-go-white text-go-white
           px-8 py-3 font-mono text-sm tracking-widest uppercase
           transition-colors duration-200"
  >
    Get in touch
  </a>

  <!--
    Scroll indicator — subtle nudge to explore beyond the fold.
    Hidden on very short viewports where it would overlap content.
    @co-1
  -->
  </div><!-- end text content -->

  <!--
    Scroll indicator — absolute to section bottom so it doesn't affect text layout.
    @co-1
  -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden sm:flex flex-col items-center gap-2 opacity-30">
    <span class="font-mono text-xs tracking-widest uppercase">Scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" aria-hidden="true">
      <rect x="6" y="0" width="4" height="4" fill="currentColor" opacity="0.5"/>
      <rect x="6" y="6" width="4" height="4" fill="currentColor" opacity="0.7"/>
      <rect x="6" y="12" width="4" height="4" fill="currentColor"/>
    </svg>
  </div>
</section>
