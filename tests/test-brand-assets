#!/usr/bin/env bash
# tests/test-brand-assets — structural validator for logo assets
# Satisfies: @co-1 (logo visible on homepage)

set -euo pipefail

PASS=0
FAIL=0
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ASSETS="$ROOT/src/assets"

pass() { echo "  PASS: $1"; ((PASS++)) || true; }
fail() { echo "  FAIL: $1"; ((FAIL++)) || true; }

echo "=== Brand asset structural tests ==="

# Primary logo — PNG provided by client
[[ -f "$ASSETS/god-object-logo.png" ]] \
  && pass "god-object-logo.png exists" \
  || fail "god-object-logo.png missing"

# Favicon SVG — sun symbol, still used
[[ -f "$ASSETS/favicon.svg" ]] \
  && pass "favicon.svg exists" \
  || fail "favicon.svg missing"

grep -q 'viewBox' "$ASSETS/favicon.svg" 2>/dev/null \
  && pass "favicon.svg has viewBox" \
  || fail "favicon.svg missing viewBox"

circles=$(grep -c '<circle' "$ASSETS/favicon.svg" 2>/dev/null || echo 0)
[[ "$circles" -ge 2 ]] \
  && pass "favicon.svg has sun symbol (≥2 circles)" \
  || fail "favicon.svg missing sun symbol circles (found $circles)"

# Logo-mark SVG — kept for small-size use (nav icon, etc.)
[[ -f "$ASSETS/logo-mark.svg" ]] \
  && pass "logo-mark.svg exists" \
  || fail "logo-mark.svg missing"

grep -q 'currentColor' "$ASSETS/logo-mark.svg" 2>/dev/null \
  && pass "logo-mark.svg uses currentColor" \
  || fail "logo-mark.svg does not use currentColor"

echo ""
echo "Results: $PASS passed, $FAIL failed"
[[ $FAIL -eq 0 ]]
