#!/usr/bin/env bash
# tests/run — single entrypoint for all project tests
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PASS=0
FAIL=0

run_suite() {
  local name="$1" script="$2"
  echo ""
  if bash "$script"; then
    ((PASS++)) || true
  else
    echo "  SUITE FAILED: $name"
    ((FAIL++)) || true
  fi
}

run_suite "scaffold"      "$ROOT/tests/test-scaffold"
run_suite "brand-assets" "$ROOT/tests/test-brand-assets"
run_suite "hero"         "$ROOT/tests/test-hero"
run_suite "nav"          "$ROOT/tests/test-nav"
run_suite "services"     "$ROOT/tests/test-services"
run_suite "footer"       "$ROOT/tests/test-footer"

echo ""
echo "=== Test run complete: $PASS suite(s) passed, $FAIL suite(s) failed ==="
[[ $FAIL -eq 0 ]]
